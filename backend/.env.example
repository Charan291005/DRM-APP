# DRM Guard Backend — Environment Variables
# Copy this file to .env and fill in the values

# ── Security ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_key_here_change_this_in_production

# JWT token expiry in minutes (default 60 min = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (development - no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./drm_guard.db

# PostgreSQL (production - uncomment and fill in):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/drmguard

# ── Server ───────────────────────────────────────────────────────────────────
# Host and port for uvicorn
HOST=0.0.0.0
PORT=8000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the web dashboard
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
